{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Amply Music Player",
  "version": "1.5.0",
  "identifier": "AdithyaKV.AmplyMusicPlayer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Amply",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$AUDIO/**",
          "$HOME/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Adithya KV",
    "shortDescription": "Amply offline music player",
    "longDescription": "Amply is a smart offline music player for local libraries, built to feel like a modern streaming app while staying entirely local.",
    "category": "Music",
    "copyright": "Copyright (c) 2026 Adithya KV",
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}
